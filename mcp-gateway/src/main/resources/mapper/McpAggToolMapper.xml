<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.imawx.mcp.gateway.mapper.McpAggToolMapper">

    <resultMap id="BaseResultMap" type="com.imawx.mcp.gateway.entity.do_.McpAggToolDO">
        <id column="id" property="id"/>
        <result column="agg_name" property="aggName"/>
        <result column="backend_id" property="backendId"/>
        <result column="tool_name" property="toolName"/>
        <result column="description" property="description"/>
        <result column="input_schema" property="inputSchema"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectByBackendId" resultMap="BaseResultMap">
        SELECT id, agg_name, backend_id, tool_name, description, input_schema, create_time, update_time
        FROM mcp_agg_tool
        WHERE backend_id = #{backendId}
        ORDER BY agg_name
    </select>

    <select id="countByBackendId" resultType="long">
        SELECT COUNT(*) FROM mcp_agg_tool WHERE backend_id = #{backendId}
    </select>

    <select id="selectAllOrdered" resultMap="BaseResultMap">
        SELECT id, agg_name, backend_id, tool_name, description, input_schema, create_time, update_time
        FROM mcp_agg_tool
        ORDER BY agg_name
    </select>
</mapper>